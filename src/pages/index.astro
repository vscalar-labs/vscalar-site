---
import Base from '../layouts/Base.astro';
---

<Base title="Enterprise Transformation Intelligence" description="VScalar builds unified intelligence systems for complex enterprise transformation.">

  <section class="hero">
    <div class="hero-content">
      <h1>Enterprise Transformation Intelligence</h1>
      <p class="tagline">Give us the data. We'll show you what matters.</p>
      <p class="subtitle">VScalar builds unified intelligence systems for complex enterprise transformation.</p>
      <div class="buttons">
        <a class="btn primary" href="/platform">Explore Platform</a>
        <a class="btn secondary" href="/research">Research &amp; Insights</a>
      </div>
    </div>
  </section>

  <section class="section">
    <h2>Focus Areas</h2>
    <div class="cards">
      <div class="card">
        <h3>Cloud Migration</h3>
        <p>Discovery &amp; assessment, integration, migration planning, modernization, sizing, dependency understanding, design and transformation execution support.</p>
      </div>
      <div class="card">
        <h3>Operations</h3>
        <p>Operational intelligence, observability insights, capacity understanding, automation opportunities, and AIOps-driven improvement.</p>
      </div>
      <div class="card">
        <h3>Zero Trust Security</h3>
        <p>Security visibility, firewall intelligence, connectivity analysis, segmentation understanding, micro-segmentation, policy enforcement and risk-aware transformation planning.</p>
      </div>
      <div class="card">
        <h3>Enterprise Architecture</h3>
        <p>Architecture assessment, target-state planning, technology rationalization, standards alignment, and transformation roadmaps.</p>
      </div>
      <div class="card">
        <h3>Research &amp; Innovation</h3>
        <p>Exploring applied AI, knowledge systems, decision intelligence, and new methods for enterprise transformation.</p>
      </div>
      <div class="card">
        <h3>AI-Assisted Delivery</h3>
        <p>Human-led architecture and engineering accelerated by AI, ML, deterministic analytics, and domain-specific intelligence systems.</p>
      </div>
    </div>
  </section>

  <section class="platform">
    <h2>Built Around a Unified Enterprise Data Hub</h2>
    <p>
      VScalar is designed around a Unified Enterprise Data Hub that brings together data from
      infrastructure, applications, cloud platforms, network telemetry, security systems,
      observability tools, operations platforms, and enterprise architecture sources.
    </p>
    <p>
      This common intelligence layer enables assessment, planning, modernization, migration,
      security analysis, operational improvement, and decision support across complex enterprise environments.
    </p>
  </section>

  <section class="section">
    <h2>Foundational Intelligence Services</h2>
    <div class="cards">
      <div class="card">
        <h3>Inventory Intelligence</h3>
        <p>Understand assets, environments, ownership, technology stacks, readiness, and transformation scope.</p>
      </div>
      <div class="card">
        <h3>Dependency Intelligence</h3>
        <p>Map relationships across applications, infrastructure, databases, services, and communication paths.</p>
      </div>
      <div class="card">
        <h3>Migration Intelligence</h3>
        <p>Support move groups, migration waves, sequencing, risk analysis, and transformation planning.</p>
      </div>
      <div class="card">
        <h3>Network Intelligence</h3>
        <p>Analyze routing, connectivity, hybrid paths, segmentation, dependencies, and architecture behavior.</p>
      </div>
      <div class="card">
        <h3>Security Intelligence</h3>
        <p>Support firewall analysis, policy understanding, traffic visibility, and zero-trust transformation planning.</p>
      </div>
      <div class="card">
        <h3>Architecture Intelligence</h3>
        <p>Assist with design patterns, landing zones, HA/DR, backup, cloud connectivity, and enterprise standards alignment.</p>
      </div>
    </div>
  </section>

  <section class="section light">
    <h2>Who It Helps</h2>
    <div class="pill-row">
      <span>Enterprise Architects</span>
      <span>Cloud Transformation Teams</span>
      <span>Infrastructure &amp; Operations</span>
      <span>Network Teams</span>
      <span>Security Teams</span>
      <span>Migration Programs</span>
      <span>Technology Leaders</span>
    </div>
  </section>

</Base>

---
import Base from '../layouts/Base.astro';
---

<Base title="Contact" description="Connect with VScalar for enterprise architecture, cloud migration, infrastructure transformation, applied AI, or research collaboration.">

  <section class="page-hero">
    <p class="eyebrow">Contact</p>
    <h1>Connect with VScalar</h1>
    <p class="subtitle">
      For conversations around enterprise architecture, cloud migration, infrastructure
      transformation, applied AI, or research collaboration.
    </p>
  </section>

  <section class="section">
    <h2>Get in Touch</h2>
    <div class="cards">
      <div class="card">
        <h3>Enterprise Architecture</h3>
        <p>Architecture assessment, transformation strategy, and modernization planning.</p>
      </div>
      <div class="card">
        <h3>Cloud Migration</h3>
        <p>Migration planning, dependency analysis, move groups, and infrastructure readiness.</p>
      </div>
      <div class="card">
        <h3>Research &amp; Collaboration</h3>
        <p>Applied AI, infrastructure intelligence, knowledge systems, and enterprise transformation research.</p>
      </div>
    </div>
  </section>

  <section class="platform">
    <h2>Email</h2>
    <p>contact@vscalar.com</p>
  </section>

</Base>

---
import Base from '../layouts/Base.astro';
---

<Base title="Research" description="VScalar explores how deterministic analytics, AI reasoning, knowledge systems, and domain expertise can improve enterprise transformation decisions.">

  <section class="page-hero">
    <p class="eyebrow">Research</p>
    <h1>Applied AI, Enterprise Architecture, and Infrastructure Intelligence</h1>
    <p class="subtitle">
      VScalar explores how deterministic analytics, AI reasoning, knowledge systems,
      and domain expertise can improve enterprise transformation decisions.
    </p>
  </section>

  <section class="section">
    <h2>Research Focus Areas</h2>
    <div class="cards">
      <div class="card">
        <h3>Infrastructure Intelligence</h3>
        <p>Using data-driven methods to improve assessment, planning, and transformation execution.</p>
      </div>
      <div class="card">
        <h3>Enterprise Architecture</h3>
        <p>Studying how complex enterprise systems can be assessed, modeled, and modernized.</p>
      </div>
      <div class="card">
        <h3>AI for Infrastructure</h3>
        <p>Exploring where AI, ML, and LLM reasoning can assist infrastructure teams.</p>
      </div>
      <div class="card">
        <h3>Knowledge Systems</h3>
        <p>Connecting infrastructure, application, security, and network context into meaningful knowledge.</p>
      </div>
      <div class="card">
        <h3>Migration Intelligence</h3>
        <p>Improving cloud and data center migration planning through better dependency and risk understanding.</p>
      </div>
      <div class="card">
        <h3>Decision Intelligence</h3>
        <p>Helping teams move from static reports to actionable transformation decisions.</p>
      </div>
    </div>
  </section>

  <section class="platform">
    <h2>White Papers Coming Soon</h2>
    <p>
      VScalar will publish research notes, white papers, architecture perspectives, and practical
      insights on cloud migration, infrastructure intelligence, enterprise architecture, and applied AI.
    </p>
  </section>

</Base>
